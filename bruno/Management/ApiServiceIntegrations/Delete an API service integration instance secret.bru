meta {
  name: Delete an API service integration instance secret
  type: http
  seq: 7
}

delete {
  url: {{orgUrl}}/integrations/api/v1/api-services/{{apiServiceId}}/credentials/secrets/{{secretId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Deletes an API Service Integration instance Secret by `secretId`. You can only delete an inactive Secret.

**Responses:**
- `204`: No Content
- `401`: 
- `403`: 
- `404`: 
- `429`:
}
