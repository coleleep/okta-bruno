meta {
  name: Delete an SMTP server configuration
  type: http
  seq: 5
}

delete {
  url: {{orgUrl}}/api/v1/email-servers/{{emailServerId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Deletes the specified custom SMTP server configuration

**Responses:**
