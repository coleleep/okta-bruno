  type: http
  seq: 9
}

get {
  url: {{orgUrl}}/api/v1/idps/{{idpId}}/credentials/keys/{{kid}}
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Retrieves a specific identity provider (IdP) key credential by `kid`

