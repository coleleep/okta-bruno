meta {
  name: Retrieve all user role governance sources
  type: http
  seq: 6
}

get {
  url: {{orgUrl}}/api/v1/users/{{userId}}/roles/{{roleAssignmentId}}/governance
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Retrieves the governance sources of a role (identified by `roleAssignmentId`) that's assigned to a user (identified by `userId`)

**Responses:**
- `200`: Success
- `403`: 
- `404`: 
- `429`:
}
