meta {
  name: Update an Okta managed user account
  type: http
  seq: 4
}

patch {
  url: {{orgUrl}}/privileged-access/api/v1/okta-service-accounts/{{id}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: SSWS {{apiKey}}
}

body:json {
  {
