meta {
  name: List all subscriptions for a user
  type: http
  seq: 5
}

get {
  url: {{orgUrl}}/api/v1/users/{{userId}}/subscriptions
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Lists all subscriptions available to a specified user. Returns an `AccessDeniedException` message if requests are made for another user.

**Responses:**
- `200`: Success
- `403`: 
- `404`: Not Found
- `429`:

**Path parameters:**
- `{{userId}}`
}
