meta {
  name: Delete a group push mapping
  type: http
  seq: 5
}

delete {
  url: {{orgUrl}}/api/v1/apps/{{appId}}/group-push/mappings/{{mappingId}}
  body: none
  auth: none
}

params:query {
  deleteTargetGroup: False
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Deletes a specific group push mapping. The group push mapping must be in an `INACTIVE` state.

**Responses:**
- `204`: No Content
- `401`: 
- `403`: Forbidden
- `404`: 
- `429`:
}
