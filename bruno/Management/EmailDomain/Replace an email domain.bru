meta {
  name: Replace an email domain
  type: http
  seq: 4
}

put {
  url: {{orgUrl}}/api/v1/email-domains/{{emailDomainId}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: SSWS {{apiKey}}
}

body:json {
  {
    "displayName": "",
    "userName": ""
  }
}

docs {
Replaces associated username and sender display name by `emailDomainId`

**Responses:**
- `200`: OK
- `400`: 
- `403`: 
- `404`: 
- `429`:
}
