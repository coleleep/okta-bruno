meta {
  name: Delete an IdP key credential
  type: http
  seq: 5
}

delete {
  url: {{orgUrl}}/api/v1/idps/credentials/keys/{{kid}}
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Deletes a specific identity provider (IdP) key credential by `kid` if it isn't currently being used by an active or inactive IdP

**Responses:**
- `204`: No Content
- `403`: 
- `404`: 
- `429`:
}
