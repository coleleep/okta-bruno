meta {
  name: Replace an IdP key credential
  type: http
  seq: 4
}

put {
  url: {{orgUrl}}/api/v1/idps/credentials/keys/{{kid}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: SSWS {{apiKey}}
}

body:json {
  {
    "created": "2016-01-03T18:15:47.000Z",
    "e": "AQAB",
    "expiresAt": "2016-01-03T18:15:47.000Z",
    "kid": "your-key-id",
    "kty": "RSA",
    "lastUpdated": "2016-01-03T18:15:47.000Z",
    "n": "",
    "use": "sig",
    "x5c": [
      ""
    ],
    "x5t#S256": "wzPVobIrveR1x-PCbjsFGNV-6zn7Rm9KuOWOG4Rk6jE"
  }
}

docs {
Replaces an identity provider (IdP) key credential by `kid`

**Responses:**
- `200`: Success
- `400`: 
- `403`: 
- `404`: 
- `429`:
}
