meta {
  name: Delete an OAuth 2.0 client secret
  type: http
  seq: 10
}

delete {
  url: {{orgUrl}}/api/v1/apps/{{appId}}/credentials/secrets/{{secretId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Deletes an OAuth 2.0 client secret by `secretId`. You can only delete an inactive secret.

**Responses:**
- `204`: No Content
- `400`: Bad Request
- `401`: 
- `403`: 
- `404`: 
- `429`:
}
