meta {
  name: Create a device assurance policy
  type: http
  seq: 2
}

post {
  url: {{orgUrl}}/api/v1/device-assurances
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: SSWS {{apiKey}}
}

body:json {
  {
    "createdBy": "",
    "createdDate": "",
    "devicePostureChecks": {
      "include": [
        {
          "variableName": "macOSFirewall",
          "value": "1"
        },
        {
          "variableName": "windowsFirewall",
          "value": "1"
        }
      ]
    },
    "displayRemediationMode": "SHOW",
    "gracePeriod": {
      "type": "BY_DATE_TIME"
    },
    "id": "",
    "lastUpdate": "",
    "lastUpdatedBy": "",
    "name": "",
    "platform": "ANDROID",
    "_links": {
      "self": ""
    }
  }
}

docs {
Creates a new device assurance policy

**Responses:**
- `200`: OK
- `400`: 
- `403`: 
- `429`:
}
