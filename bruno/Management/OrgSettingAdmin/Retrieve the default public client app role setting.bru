meta {
  name: Retrieve the default public client app role setting
  type: http
  seq: 5
}

get {
  url: {{orgUrl}}/api/v1/org/settings/clientPrivilegesSetting
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: SSWS {{apiKey}}
}

docs {
Retrieves the org setting to assign the [Super Admin role](https://help.okta.com/okta_help.htm?type=oie&id=ext_superadmin) to new public client apps

**Responses:**
- `200`: Success
- `403`: 
- `429`:
}
