meta {
  name: /par
  type: http
  seq: 14
}

post {
  url: {{orgUrl}}/oauth2/{{authorizationServerId}}/v1/par
  body: json
  auth: basic
}

headers {
  Accept: application/json
  Content-Type: application/json
}

