  username: {{oauthClientId}}
  password: {{oauthClientSecret}}
}

body:json {
  {
    "client_id": "",
    "code_challenge": "",
    "code_challenge_method": "",
    "display": "",
    "idp": "",
    "idp_scope": "",
    "login_hint": "",
    "max_age": 0,
    "nonce": "",
    "prompt": "",
