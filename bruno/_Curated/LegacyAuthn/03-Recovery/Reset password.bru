meta {
  name: Reset password
  type: http
  seq: 8
}

post {
  url: {{orgUrl}}/api/v1/authn/credentials/reset_password
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "stateToken": "{{stateToken}}",
    "newPassword": ""
  }
}

docs {
Sets a new password during a recovery flow. Transaction must be in `PASSWORD_RESET` state.

`newPassword` must satisfy the org's password policy.
}
