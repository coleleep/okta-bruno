meta {
  name: Answer security question
  type: http
  seq: 6
}

post {
  url: {{orgUrl}}/api/v1/authn/recovery/answer
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "stateToken": "{{stateToken}}",
    "answer": ""
  }
}

docs {
Answers the user's security question during recovery. Required for orgs that have security questions enabled in the password policy.
}
