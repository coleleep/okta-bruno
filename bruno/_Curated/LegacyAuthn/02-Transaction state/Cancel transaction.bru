meta {
  name: Cancel transaction
  type: http
  seq: 2
}

post {
  url: {{orgUrl}}/api/v1/authn/cancel
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "stateToken": "{{stateToken}}"
  }
}

docs {
Cancels the active authentication transaction. Returns the relay state if one was provided.
}
